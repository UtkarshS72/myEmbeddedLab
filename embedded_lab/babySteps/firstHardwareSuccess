#include <stdint.h>

#define GPIO_OUT_REG    0x3FF44004
#define GPIO_ENABLE_REG 0x3FF44020

void setup() {

    volatile uint32_t *gpio_out = (uint32_t*) GPIO_OUT_REG;
    volatile uint32_t *gpio_en  = (uint32_t*) GPIO_ENABLE_REG;

    // enable GPIO2 as output
    *gpio_en |= (1 << 2);

    // turn LED ON
    *gpio_out |= (1 << 2);
}

void loop(){}
